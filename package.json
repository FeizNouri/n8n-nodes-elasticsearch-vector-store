{
	"name": "n8n-nodes-elasticsearch-vector-store",
	"version": "0.3.2",
	"description": "n8n community node for using Elasticsearch as a LangChain vector store (RAG, similarity search, AI agent tool)",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"elasticsearch",
		"vector-store",
		"vectorstore",
		"rag",
		"langchain",
		"ai",
		"embeddings"
	],
	"license": "MIT",
	"homepage": "https://github.com/FeizNouri/n8n-nodes-elasticsearch-vector-store#readme",
	"author": {
		"name": "Feiz Nouri",
		"email": "feiznouri@gmail.com",
		"url": "https://feiznouri.ovh"
	},
	"contributors": [
		{
			"name": "Hurence",
			"url": "https://www.hurence.com"
		}
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/FeizNouri/n8n-nodes-elasticsearch-vector-store.git"
	},
	"bugs": {
		"url": "https://github.com/FeizNouri/n8n-nodes-elasticsearch-vector-store/issues"
	},
	"overrides": {
		"isolated-vm": "^5.0.0"
	},
	"main": "index.js",
	"scripts": {
		"build": "rimraf dist && tsc -p tsconfig.build.json && gulp build:icons",
		"dev": "tsc -p tsconfig.build.json --watch",
		"format": "prettier src test --write",
		"lint": "eslint src package.json",
		"lintfix": "eslint src package.json --fix",
		"test": "jest",
		"test:integration": "jest -c jest.integration.config.js",
		"prepublishOnly": "npm run build && npm run lint -c .eslintrc.prepublish.js src package.json"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/ElasticsearchVectorApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/VectorStoreElasticsearch/VectorStoreElasticsearch.node.js"
		]
	},
	"dependencies": {
		"@elastic/elasticsearch": "^8.14.0",
		"@langchain/core": "^0.3.0"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"devDependencies": {
		"@types/jest": "^29.5.14",
		"@types/node": "^20.11.30",
		"@typescript-eslint/parser": "^7.15.0",
		"eslint": "^8.57.0",
		"eslint-plugin-n8n-nodes-base": "^1.16.3",
		"gulp": "^4.0.2",
		"jest": "^29.7.0",
		"n8n-workflow": "*",
		"prettier": "^3.3.2",
		"rimraf": "^5.0.7",
		"ts-jest": "^29.4.11",
		"typescript": "^5.5.3"
	}
}
